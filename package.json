{
	"name": "proj",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "eslint .",
		"lint:nix": "LIBGBM_PATH=\"$(nix eval --raw nixpkgs#libgbm.outPath)/lib\" NIX_LD_LIBRARY_PATH=\"$LIBGBM_PATH:${NIX_LD_LIBRARY_PATH:-}\" LD_LIBRARY_PATH=\"$LIBGBM_PATH:${LD_LIBRARY_PATH:-}\" pnpm lint",
		"test:e2e": "playwright test",
		"test:e2e:nix": "LIBGBM_PATH=\"$(nix eval --raw nixpkgs#libgbm.outPath)/lib\" NIX_LD_LIBRARY_PATH=\"$LIBGBM_PATH:${NIX_LD_LIBRARY_PATH:-}\" LD_LIBRARY_PATH=\"$LIBGBM_PATH:${LD_LIBRARY_PATH:-}\" pnpm test:e2e",
		"check:pr": "pnpm lint && pnpm test:e2e",
		"check:pr:nix": "LIBGBM_PATH=\"$(nix eval --raw nixpkgs#libgbm.outPath)/lib\" NIX_LD_LIBRARY_PATH=\"$LIBGBM_PATH:${NIX_LD_LIBRARY_PATH:-}\" LD_LIBRARY_PATH=\"$LIBGBM_PATH:${LD_LIBRARY_PATH:-}\" pnpm check:pr"
	},
	"dependencies": {
		"deps": "^1.0.0",
		"playwright": "^1.58.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"autoprefixer": "^10.4.24",
		"eslint": "^10.0.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.3.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.2.1",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1"
	}
}